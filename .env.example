# API Tokens Template
# Copy this to .env and encrypt with: dotenvx encrypt
#
# To create your secrets file:
# 1. Copy this file: cp .env.example .env
# 2. Add your API keys
# 3. Encrypt: dotenvx encrypt
# 4. Commit .env (safe - it's encrypted)
#
# To add new secrets: dotenvx set NEW_KEY "value"
# To run with secrets: dotenvx run -- <command>

# AI Provider API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...

# Add other secrets as needed:
# GITHUB_TOKEN=ghp_...
# FLY_API_TOKEN=...
