{
  "[python]": {
    "editor.formatOnType": true
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "workbench.editorAssociations": {
    "*.csv": "default",
    "*.bpmn": "default"
  },
  "breadcrumbs.enabled": true,
  "breadcrumbs.symbolPath": "off",
  "clock.dateFormat": "HH:MM:ss",
  "code-runner.clearPreviousOutput": true,
  "code-runner.runInTerminal": true,
  "cSpell.userWords": ["fastify", "recurly", "zuora"],
  "debug.allowBreakpointsEverywhere": true,
  "debug.inlineValues": "on",
  "debug.terminal.clearBeforeReusing": true,
  "debug.toolBarLocation": "docked",
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.renderSideBySide": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.tslint": "explicit"
  },
  "editor.cursorStyle": "line",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fontFamily": "Fira Code",
  "editor.fontLigatures": true,
  "editor.formatOnPaste": true,
  "editor.guides.bracketPairs": "active",
  "editor.hover.enabled": "on",
  "editor.inlineSuggest.enabled": true,
  "editor.insertSpaces": false,
  "editor.lineNumbers": "on",
  "editor.linkedEditing": true,
  "editor.minimap.enabled": false,
  "editor.semanticHighlighting.enabled": true,
  "editor.snippetSuggestions": "top",
  "editor.suggest.preview": true,
  "editor.suggest.showIcons": true,
  "editor.suggest.showKeywords": true,
  "editor.tabSize": 8,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.wordSeparators": "/\\()\"':,.;<>~!@#$%^&*|+=[]{}`?-",
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "explorer.autoReveal": false,
  "explorer.confirmDelete": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js, ${capture}.typegen.ts, ${capture}.typegen.ts",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts, ${capture}.typegen.ts, ${capture}.typegen.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml",
    "*.cts": "${capture}.typegen.ts, ${capture}.typegen.ts",
    "*.mts": "${capture}.typegen.ts, ${capture}.typegen.ts",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
  },
  "files.exclude": {
    "**/.gtm": true,
    "**/.jest-cache": true,
    "**/.vscode": false,
    "**/build": false,
    "**/coverage": false,
    "**/dist": false
  },
  "git.autofetch": false,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.ignoreRebaseWarning": true,
  "githubPullRequests.createOnPublishBranch": "never",
  "githubPullRequests.pullBranch": "never",
  "githubPullRequests.queries": [
    {
      "label": "Local Pull Request Branches",
      "query": "default"
    },
    {
      "label": "Waiting For My Review",
      "query": "is:open review-requested:${user}"
    },
    {
      "label": "Assigned To Me",
      "query": "is:open assignee:${user}"
    },
    {
      "label": "Created By Me (Open)",
      "query": "is:open author:${user}"
    },
    {
      "label": "Created By Me (Closed)",
      "query": "is:closed author:${user}"
    },
    {
      "label": "All Open",
      "query": "default"
    }
  ],
  "gitlens.defaultDateFormat": "YYYY-MM-DD HH:mm:ss",
  "gitlens.defaultDateShortFormat": "YYYY-MM-DD",
  "gitlens.keymap": "none",
  "gitProjectManager.baseProjectsFolders": ["/home/larr/git"],
  "gitProjectManager.checkRemoteOrigin": false,
  "gitProjectManager.ignoredFolders": ["node_modules"],
  "gitProjectManager.maxDepthRecursion": 4,
  "gitProjectManager.openInNewWindow": true,
  "gitProjectManager.storeRepositoriesBetweenSessions": true,
  "html.autoClosingTags": true,
  "html.format.wrapAttributes": "force-aligned",
  "html.format.wrapLineLength": 80,
  "javascript.autoClosingTags": true,
  "javascript.suggest.autoImports": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "markdown.extension.toc.updateOnSave": true,
  "markdown.preview.breaks": true,
  "markdownlint.config": {
    "MD013": false,
    "MD026": false,
    "MD033": false
  },
  "search.exclude": {
    "**/*.vscode": true,
    "**/.dccache": true,
    "**/.git": true,
    "**/build": true,
    "**/coverage": true,
    "**/dist": true,
    "**/testdata": true
  },
  "search.showLineNumbers": true,
  "search.useIgnoreFiles": false,
  "security.workspace.trust.untrustedFiles": "open",
  "spotify.showMuteUnmuteVolumeButton": false,
  "spotify.showSignInButton": true,
  "spotify.showSignOutButton": false,
  "task.autoDetect": "off",
  "terminal.integrated.fontFamily": "MesloLGS NF",
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.showExitAlert": false,
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "vim.foldfix": true,
  "vim.handleKeys": {
    "<C-b>": false,
    "<C-d>": false
  },
  "vim.sneak": true,
  "vim.sneakUseIgnorecaseAndSmartcase": true,
  "vim.useSystemClipboard": true,
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "after": ["p", "g", "v", "y"],
      "before": ["p"]
    }
  ],
  "window.menuBarVisibility": "toggle",
  "window.openFoldersInNewWindow": "on",
  "window.customMenuBarAltFocus": false,
  "workbench.colorCustomizations": {
    "[Atom One Dark]": {
      "editor.findMatchBackground": "#FFFF0020",
      "editor.selectionBackground": "#FFFF0050",
      "editor.selectionHighlightBackground": "#FFFF0020",
      "statusBar.debuggingBackground": "#263238"
    }
  },
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.list.openMode": "doubleClick",
  "workbench.startupEditor": "none",
  "yaml.format.singleQuote": true,
  "workbench.iconTheme": "material-icon-theme",
  "extensions.ignoreRecommendations": true,
  "editor.formatOnSave": true,
  "redhat.telemetry.enabled": true,
  "workbench.colorTheme": "Atom One Dark",
  "diffEditor.codeLens": true,
  "jqPlayground.binaryPath": "/usr/bin/jq",
  "continue.enableTabAutocomplete": false,
  "workbench.sideBar.location": "left",
  "debug.javascript.autoAttachFilter": "disabled",
  "continue.enableQuickActions": true,
  "wikitext.host": "en.wikipedia.org",
  "markdown-preview-enhanced.previewTheme": "atom-light.css",
  "emmet.excludeLanguages": ["markdown"],
  "[markdown]": {
    "editor.inlineSuggest.enabled": true,
    "editor.acceptSuggestionOnEnter": "on",
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 120
  },
  "todotxtmode.todoFilename": "todo.md",
  "todotxtmode.doneFilename": "done.md",
  "todotxtmode.somedayFilename": "someday.md",
  "todotxtmode.waitingFilename": "waiting.md",
  "todotxtmode.todoFilePattern": "^.*\\.md$",
  "todotxtmode.excludeDecorationsFilePattern": "^done\\.md$",
  "todotxtmode.addCreatedAt": false,
  "filterlines.createNewTab": false,
  "vim.easymotion": true,
  "editor.smoothScrolling": true,
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["f"],
      "after": ["<leader>", "<leader>", "s"]
    }
  ],
  "vim.visualModeKeyBindings": [
    {
      "before": ["f"],
      "after": ["<leader>", "<leader>", "s"]
    }
  ],
  "markdown.marp.browser": "chrome",
  "cSpell.blockCheckingWhenLineLengthGreaterThan": 100000,
  "workbench.editor.enablePreview": false,
  "gitlens.advanced.messages": {
    "suppressIntegrationDisconnectedTooManyFailedRequestsWarning": true
  },
  "notebook.lineNumbers": "on",
  "errorLens.enabledDiagnosticLevels": ["error"],
  "jupyter.interactiveWindow.textEditor.executeSelection": true,
  "excalidraw.theme": "dark",
  "excalidraw.image": {
    "exportScale": 1,
    "exportWithBackground": true,
    "exportWithDarkMode": false
  },
  "sqltools.useNodeRuntime": true,
  "hediet.vscode-drawio.resizeImages": null,
  "continue.pauseCodebaseIndexOnStart": true,
  "[sql]": {
    "editor.defaultFormatter": null
  },
  "platformio-ide.autoOpenPlatformIOIniFile": false,
  "auto-build.defaultEnv.name": "STM32F103RC_btt_USB",
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "docker.extension.enableComposeLanguageServer": false,
  "explorer.confirmDragAndDrop": false,
  "zig.zls.enabled": "on",
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "criticmarkup.addition",
        "settings": {
          "foreground": "#00bb00"
        }
      },
      {
        "scope": "criticmarkup.deletion",
        "settings": {
          "foreground": "#dd0000"
        }
      },
      {
        "scope": "criticmarkup.substitution",
        "settings": {
          "foreground": "#ff8600"
        }
      },
      {
        "scope": "criticmarkup.comment",
        "settings": {
          "foreground": "#0000bb"
        }
      },
      {
        "scope": "criticmarkup.highlight",
        "settings": {
          "foreground": "#aa53a9"
        }
      }
    ]
  },
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true
    },
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "markdown-mermaid.darkModeTheme": "dark",
  "mermaidChart.aiVendor": "openai",
  "markdown-preview-enhanced.chromePath": "/usr/bin/google-chrome",
  "python.defaultInterpreterPath": "/bin/python3",
  "claudeCode.useTerminal": true,
  "csv.enabled": true,
  "claudeCode.preferredLocation": "sidebar",
  "github.copilot.nextEditSuggestions.enabled": true
}
