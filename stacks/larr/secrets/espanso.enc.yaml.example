# Espanso config files (encrypt with: sops -e -i espanso.enc.yaml)
# Keys are relative paths under ~/.config/espanso/
espanso_config:
  config/default.yml: |
    toggle_key: OFF
    inject_delay: 0
    keyboard_layout:
      layout: et

  match/base.yml: |
    matches:
      - trigger: "::name"
        replace: Your Name
      - trigger: "::email"
        replace: your@email.com
      - trigger: "::date"
        replace: "{{mydate}}"
        vars:
          - name: mydate
            type: date
            params:
              format: "%Y-%m-%d"
