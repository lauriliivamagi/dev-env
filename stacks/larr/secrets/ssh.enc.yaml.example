# SSH Keys Template
# Copy this to ssh.enc.yaml and encrypt with: sops -e -i ssh.enc.yaml
#
# To create your secrets file:
# 1. Copy this file: cp ssh.enc.yaml.example ssh.enc.yaml
# 2. Add your SSH keys (unencrypted)
# 3. Encrypt: sops -e -i ssh.enc.yaml
# 4. Commit the encrypted file (safe to share)
#
# To edit later: sops ssh.enc.yaml (opens decrypted in $EDITOR)

ssh_keys:
  # Private key (will get 600 permissions)
  id_ed25519: |
    -----BEGIN OPENSSH PRIVATE KEY-----
    your-key-content-here
    -----END OPENSSH PRIVATE KEY-----

  # Public key (will get 644 permissions)
  id_ed25519.pub: |
    ssh-ed25519 AAAA... user@host

  # Add more keys as needed:
  # id_github: |
  #   -----BEGIN OPENSSH PRIVATE KEY-----
  #   ...
  #   -----END OPENSSH PRIVATE KEY-----
