# Snippet text files for clipboard-based text expansion
# Edit values, then encrypt: sops -e -i wtype.enc.yaml
#
# Usage:
#   1. Press Ctrl+Insert → opens fzf picker in ghostty
#   2. Select snippet → copied to clipboard
#   3. Paste with Ctrl+V
#
# Dynamic content uses $(command) syntax
snippets:
  name.txt: Your Name
  email.txt: your@email.com
  phone.txt: "+1234567890"
  date.txt: "$(date +%Y-%m-%d)"
  timestamp.txt: "$(date +%Y-%m-%dT%H:%M:%S)"
  signature.txt: |
    Kind regards,
    Your Name
    Your Title
